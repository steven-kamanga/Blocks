@if (Show)
{
    <div class="app-modal-backdrop" @onclick="OnClose">
        <div class="app-modal" @onclick:stopPropagation="true">
            <div class="app-modal-header">
                <h3 class="app-modal-title">Add Material</h3>
                <button class="btn btn-ghost btn-sm" @onclick="OnClose">x</button>
            </div>
            <div class="app-modal-body">
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="message message-error">@ErrorMessage</div>
                }
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Material Name</label>
                        <input type="text" class="form-input" @bind="NewMaterial.Name" placeholder="e.g., Cement, Sand" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Unit</label>
                        <select class="form-input" @bind="NewMaterial.Unit">
                            <option value="kg">kg</option>
                            <option value="bags">bags</option>
                            <option value="liters">liters</option>
                            <option value="tons">tons</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Initial Stock</label>
                        <input type="number" class="form-input" @bind="NewMaterial.StockQuantity" min="0" step="0.01" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Unit Cost</label>
                        <input type="number" class="form-input" @bind="NewMaterial.UnitCost" min="0" step="0.01" />
                    </div>
                </div>
            </div>
            <div class="app-modal-footer">
                <button class="btn" @onclick="OnClose">Cancel</button>
                <button class="btn btn-primary" @onclick="CreateMaterial" disabled="@Saving">
                    @(Saving ? "Saving..." : "Add Material")
                </button>
            </div>
        </div>
    </div>
}