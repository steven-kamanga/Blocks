@page "/machines"
@rendermode InteractiveServer

<div class="page-header">
    <div>
        <h1 class="page-title">Machines</h1>
        <p class="page-subtitle">Manage block-making machines</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreateModal">+ Add Machine</button>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Total Machines</div>
        <div class="stat-value">@_totalCount</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Active</div>
        <div class="stat-value">@_machines.Count(m => m.IsActive)</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Total Capacity</div>
        <div class="stat-value">@_machines.Where(m => m.IsActive).Sum(m => m.BlocksPerBatch) blocks/cycle</div>
    </div>
</div>

@if (_isLoading)
{
    <div class="loading">
        <div class="spinner"></div>
        Loading machines...
    </div>
}
else if (_machines.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">[ ]</div>
        <p>No machines yet</p>
        <button class="btn" @onclick="OpenCreateModal">Add your first machine</button>
    </div>
}
else
{
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Site</th>
                    <th>Block Size</th>
                    <th>Output/Cycle</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var machine in _machines)
                {
                    <tr>
                        <td class="text-mono">@machine.Id.ToString("D3")</td>
                        <td>@machine.Name</td>
                        <td class="text-muted">@machine.SiteName</td>
                        <td class="text-muted">@machine.BlockSize</td>
                        <td class="text-mono">@machine.BlocksPerBatch blocks</td>
                        <td>
                            <span class="status-badge @(machine.IsActive ? "status-active" : "status-inactive")">
                                @(machine.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>
                            <div class="actions">
                                <button class="btn btn-sm btn-ghost" @onclick="() => ToggleStatus(machine)">
                                    @(machine.IsActive ? "Deactivate" : "Activate")
                                </button>
                                <button class="btn btn-sm btn-ghost" @onclick="() => OpenEditModal(machine)">Edit</button>
                                <button class="btn btn-sm btn-ghost btn-danger"
                                        @onclick="() => OpenDeleteModal(machine)">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (_totalCount > 0)
    {
        <div class="pagination">
            <button class="btn btn-sm btn-ghost" disabled="@(!_hasPreviousPage)" @onclick="PreviousPage">&lt; Prev</button>
            @for (int i = 1; i <= _totalPages; i++)
            {
                var pageNum = i;
                <button class="btn btn-sm @(pageNum == _currentPage ? "btn-primary" : "btn-ghost")"
                        @onclick="() => GoToPage(pageNum)">@pageNum</button>
            }
            <button class="btn btn-sm btn-ghost" disabled="@(!_hasNextPage)" @onclick="NextPage">Next &gt;</button>
            <span class="pagination-info">Page @_currentPage of @_totalPages (@_totalCount total)</span>
        </div>
    }
}

@if (_showCreateModal)
{
    <div class="app-modal-backdrop" @onclick="CloseCreateModal">
        <div class="app-modal" @onclick:stopPropagation="true">
            <div class="app-modal-header">
                <h3 class="app-modal-title">Add Machine</h3>
                <button class="btn btn-ghost btn-sm" @onclick="CloseCreateModal">x</button>
            </div>
            <div class="app-modal-body">
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="message message-error">@_errorMessage</div>
                }
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Machine Name</label>
                        <input type="text" class="form-input" @bind="_newMachine.Name" placeholder="e.g., Block Press A" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Site</label>
                        <select class="form-input" @bind="_newMachine.SiteId">
                            <option value="0">-- Select Site --</option>
                            @foreach (var site in _sites)
                            {
                                <option value="@site.Id">@site.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Block Size (W x H x L inches)</label>
                        <select class="form-input" @bind="_newMachine.BlockSize">
                            <option value="4x8x16">4 x 8 x 16</option>
                            <option value="6x8x16">6 x 8 x 16</option>
                            <option value="8x8x16">8 x 8 x 16</option>
                            <option value="12x8x16">12 x 8 x 16</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Blocks per Cycle</label>
                        <input type="number" class="form-input" @bind="_newMachine.BlocksPerBatch" min="1" />
                    </div>
                </div>
            </div>
            <div class="app-modal-footer">
                <button class="btn" @onclick="CloseCreateModal">Cancel</button>
                <button class="btn btn-primary" @onclick="CreateMachine" disabled="@_isSaving">
                    @(_isSaving ? "Saving..." : "Add Machine")
                </button>
            </div>
        </div>
    </div>
}

@if (_showEditModal && _editMachine != null)
{
    <div class="app-modal-backdrop" @onclick="CloseEditModal">
        <div class="app-modal" @onclick:stopPropagation="true">
            <div class="app-modal-header">
                <h3 class="app-modal-title">Edit Machine</h3>
                <button class="btn btn-ghost btn-sm" @onclick="CloseEditModal">x</button>
            </div>
            <div class="app-modal-body">
                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="message message-error">@_errorMessage</div>
                }
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label">Machine Name</label>
                        <input type="text" class="form-input" @bind="_editRequest.Name" placeholder="e.g., Block Press A" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Site</label>
                        <select class="form-input" @bind="_editRequest.SiteId">
                            @foreach (var site in _sites)
                            {
                                <option value="@site.Id">@site.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Block Size (W x H x L inches)</label>
                        <select class="form-input" @bind="_editRequest.BlockSize">
                            <option value="4x8x16">4 x 8 x 16</option>
                            <option value="6x8x16">6 x 8 x 16</option>
                            <option value="8x8x16">8 x 8 x 16</option>
                            <option value="12x8x16">12 x 8 x 16</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Blocks per Cycle</label>
                        <input type="number" class="form-input" @bind="_editRequest.BlocksPerBatch" min="1" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Status</label>
                        <select class="form-input" @bind="_editRequest.IsActive">
                            <option value="true">Active</option>
                            <option value="false">Inactive</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="app-modal-footer">
                <button class="btn" @onclick="CloseEditModal">Cancel</button>
                <button class="btn btn-primary" @onclick="UpdateMachine" disabled="@_isSaving">
                    @(_isSaving ? "Saving..." : "Save Changes")
                </button>
            </div>
        </div>
    </div>
}

@if (_showDeleteModal && _machineToDelete != null)
{
    <div class="app-modal-backdrop" @onclick="CloseDeleteModal">
        <div class="app-modal" @onclick:stopPropagation="true">
            <div class="app-modal-header">
                <h3 class="app-modal-title">Delete Machine</h3>
                <button class="btn btn-ghost btn-sm" @onclick="CloseDeleteModal">x</button>
            </div>
            <div class="app-modal-body">
                <p>Are you sure you want to delete <strong>@_machineToDelete.Name</strong>?</p>
                <p class="text-muted">This action cannot be undone.</p>
            </div>
            <div class="app-modal-footer">
                <button class="btn" @onclick="CloseDeleteModal">Cancel</button>
                <button class="btn btn-danger" @onclick="DeleteMachine" disabled="@_isSaving">
                    @(_isSaving ? "Deleting..." : "Delete")
                </button>
            </div>
        </div>
    </div>
}