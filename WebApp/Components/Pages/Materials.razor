@page "/materials"
@using WebApp.Components.Partials.Materials
@rendermode InteractiveServer

<div class="page-header">
    <div>
        <h1 class="page-title">Raw Materials</h1>
        <p class="page-subtitle">Manage cement, sand, aggregates and other materials</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreateModal">+ Add Material</button>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Total Materials</div>
        <div class="stat-value">@_totalCount</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Total Stock Value</div>
        <div class="stat-value">MWK @_materials.Sum(m => m.StockQuantity * m.UnitCost).ToString("N0")</div>
    </div>
</div>

@if (_isLoading)
{
    <div class="loading">
        <div class="spinner"></div>
        Loading materials...
    </div>
}
else if (_materials.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">[ ]</div>
        <p>No materials yet</p>
        <button class="btn" @onclick="OpenCreateModal">Add your first material</button>
    </div>
}
else
{
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Unit</th>
                    <th>Stock</th>
                    <th>Unit Cost</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var material in _materials)
                {
                    <tr>
                        <td class="text-mono">@material.Id.ToString("D3")</td>
                        <td>@material.Name</td>
                        <td class="text-muted">@material.Unit</td>
                        <td class="text-mono">@material.StockQuantity.ToString("N0")</td>
                        <td class="text-mono">@material.UnitCost.ToString("N2")</td>
                        <td>
                            <div class="actions">
                                <button class="btn btn-sm btn-ghost" @onclick="() => OpenStockModal(material)">Update
                                    Stock</button>
                                    <button class="btn btn-sm btn-ghost" @onclick="() => OpenEditModal(material)">Edit</button>
                                    <button class="btn btn-sm btn-ghost btn-danger"
                                            @onclick="() => OpenDeleteModal(material)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_totalCount > 0)
        {
            <div class="pagination">
                <button class="btn btn-sm btn-ghost" disabled="@(!_hasPreviousPage)" @onclick="PreviousPage">&lt; Prev</button>
                @for (int i = 1; i <= _totalPages; i++)
                {
                    var pageNum = i;
                    <button class="btn btn-sm @(pageNum == _currentPage ? "btn-primary" : "btn-ghost")"
                            @onclick="() => GoToPage(pageNum)">@pageNum</button>
                }
                <button class="btn btn-sm btn-ghost" disabled="@(!_hasNextPage)" @onclick="NextPage">Next &gt;</button>
                <span class="pagination-info">Page @_currentPage of @_totalPages (@_totalCount total)</span>
            </div>
        }
    }
    <_CreateMaterialsModal OnClose="CloseCreateModal" Show="@_showCreateModal" ErrorMessage="@_errorMessage"
                  NewMaterial="@_newMaterial" Saving="@_isSaving" CreateMaterial="CreateMaterial" />

    <_DeleteMaterialsModal Show="@_showDeleteModal" MaterialToDelete="@_materialToDelete" IsSaving="@_isSaving"
                  DeleteMaterial="DeleteMaterial" OnClose="CloseDeleteModal" />

    <_UpdateMaterialsModal Show="@_showEditModal" MaterialToEdit="@_editMaterial" IsSaving="@_isSaving" ErrorMessage="@_errorMessage"
                  EditRequest="@_editRequest" OnClose="CloseEditModal" UpdateMaterial="UpdateMaterial" />
    <_ShowMaterialsModal Show="@_showStockModal" SelectedMaterial="@_selectedMaterial" />