@page "/materials"
@rendermode InteractiveServer

<div class="page-header">
    <div>
        <h1 class="page-title">Raw Materials</h1>
        <p class="page-subtitle">Manage cement, sand, aggregates and other materials</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreateModal">+ Add Material</button>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-label">Total Materials</div>
        <div class="stat-value">@_totalCount</div>
    </div>
    <div class="stat-card">
        <div class="stat-label">Total Stock Value</div>
        <div class="stat-value">MWK @_materials.Sum(m => m.StockQuantity * m.UnitCost).ToString("N0")</div>
    </div>
</div>

@if (_isLoading)
{
    <div class="loading">
        <div class="spinner"></div>
        Loading materials...
    </div>
}
else if (_materials.Count == 0)
{
    <div class="empty-state">
        <div class="empty-state-icon">[ ]</div>
        <p>No materials yet</p>
        <button class="btn" @onclick="OpenCreateModal">Add your first material</button>
    </div>
}
else
{
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Unit</th>
                    <th>Stock</th>
                    <th>Unit Cost</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var material in _materials)
                {
                    <tr>
                        <td class="text-mono">@material.Id.ToString("D3")</td>
                        <td>@material.Name</td>
                        <td class="text-muted">@material.Unit</td>
                        <td class="text-mono">@material.StockQuantity.ToString("N0")</td>
                        <td class="text-mono">@material.UnitCost.ToString("N2")</td>
                        <td>
                            <div class="actions">
                                <button class="btn btn-sm btn-ghost" @onclick="() => OpenStockModal(material)">Update
                                    Stock</button>
                                    <button class="btn btn-sm btn-ghost" @onclick="() => OpenEditModal(material)">Edit</button>
                                    <button class="btn btn-sm btn-ghost btn-danger"
                                            @onclick="() => OpenDeleteModal(material)">Delete</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_totalCount > 0)
        {
            <div class="pagination">
                <button class="btn btn-sm btn-ghost" disabled="@(!_hasPreviousPage)" @onclick="PreviousPage">&lt; Prev</button>
                @for (int i = 1; i <= _totalPages; i++)
                {
                    var pageNum = i;
                    <button class="btn btn-sm @(pageNum == _currentPage ? "btn-primary" : "btn-ghost")"
                            @onclick="() => GoToPage(pageNum)">@pageNum</button>
                }
                <button class="btn btn-sm btn-ghost" disabled="@(!_hasNextPage)" @onclick="NextPage">Next &gt;</button>
                <span class="pagination-info">Page @_currentPage of @_totalPages (@_totalCount total)</span>
            </div>
        }
    }

    @if (_showCreateModal)
    {
        <div class="app-modal-backdrop" @onclick="CloseCreateModal">
            <div class="app-modal" @onclick:stopPropagation="true">
                <div class="app-modal-header">
                    <h3 class="app-modal-title">Add Material</h3>
                    <button class="btn btn-ghost btn-sm" @onclick="CloseCreateModal">x</button>
                </div>
                <div class="app-modal-body">
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="message message-error">@_errorMessage</div>
                    }
                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">Material Name</label>
                            <input type="text" class="form-input" @bind="_newMaterial.Name" placeholder="e.g., Cement, Sand" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Unit</label>
                            <select class="form-input" @bind="_newMaterial.Unit">
                                <option value="kg">kg</option>
                                <option value="bags">bags</option>
                                <option value="liters">liters</option>
                                <option value="tons">tons</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="form-label">Initial Stock</label>
                            <input type="number" class="form-input" @bind="_newMaterial.StockQuantity" min="0" step="0.01" />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Unit Cost</label>
                            <input type="number" class="form-input" @bind="_newMaterial.UnitCost" min="0" step="0.01" />
                        </div>
                    </div>
                </div>
                <div class="app-modal-footer">
                    <button class="btn" @onclick="CloseCreateModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="CreateMaterial" disabled="@_isSaving">
                        @(_isSaving ? "Saving..." : "Add Material")
                    </button>
                </div>
            </div>
        </div>
    }

    @if (_showStockModal && _selectedMaterial != null)
    {
        <div class="app-modal-backdrop" @onclick="CloseStockModal">
            <div class="app-modal" @onclick:stopPropagation="true">
                <div class="app-modal-header">
                    <h3 class="app-modal-title">Update Stock - @_selectedMaterial.Name</h3>
                    <button class="btn btn-ghost btn-sm" @onclick="CloseStockModal">x</button>
                </div>
                <div class="app-modal-body">
                    <div class="form-group">
                        <label class="form-label">Current Stock: @_selectedMaterial.StockQuantity
                            @_selectedMaterial.Unit</label>
                            <input type="number" class="form-input" @bind="_newStockQuantity" min="0" step="0.01" />
                        </div>
                    </div>
                    <div class="app-modal-footer">
                        <button class="btn" @onclick="CloseStockModal">Cancel</button>
                        <button class="btn btn-primary" @onclick="UpdateStock" disabled="@_isSaving">
                            @(_isSaving ? "Updating..." : "Update Stock")
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (_showEditModal && _editMaterial != null)
        {
            <div class="app-modal-backdrop" @onclick="CloseEditModal">
                <div class="app-modal" @onclick:stopPropagation="true">
                    <div class="app-modal-header">
                        <h3 class="app-modal-title">Edit Material</h3>
                        <button class="btn btn-ghost btn-sm" @onclick="CloseEditModal">x</button>
                    </div>
                    <div class="app-modal-body">
                        @if (!string.IsNullOrEmpty(_errorMessage))
                        {
                            <div class="message message-error">@_errorMessage</div>
                        }
                        <div class="form-grid">
                            <div class="form-group">
                                <label class="form-label">Material Name</label>
                                <input type="text" class="form-input" @bind="_editRequest.Name" placeholder="e.g., Cement, Sand" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Unit</label>
                                <select class="form-input" @bind="_editRequest.Unit">
                                    <option value="kg">kg</option>
                                    <option value="bags">bags</option>
                                    <option value="liters">liters</option>
                                    <option value="tons">tons</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label class="form-label">Stock Quantity</label>
                                <input type="number" class="form-input" @bind="_editRequest.StockQuantity" min="0" step="0.01" />
                            </div>
                            <div class="form-group">
                                <label class="form-label">Unit Cost</label>
                                <input type="number" class="form-input" @bind="_editRequest.UnitCost" min="0" step="0.01" />
                            </div>
                        </div>
                    </div>
                    <div class="app-modal-footer">
                        <button class="btn" @onclick="CloseEditModal">Cancel</button>
                        <button class="btn btn-primary" @onclick="UpdateMaterial" disabled="@_isSaving">
                            @(_isSaving ? "Saving..." : "Save Changes")
                        </button>
                    </div>
                </div>
            </div>
        }

        @if (_showDeleteModal && _materialToDelete != null)
        {
            <div class="app-modal-backdrop" @onclick="CloseDeleteModal">
                <div class="app-modal" @onclick:stopPropagation="true">
                    <div class="app-modal-header">
                        <h3 class="app-modal-title">Delete Material</h3>
                        <button class="btn btn-ghost btn-sm" @onclick="CloseDeleteModal">x</button>
                    </div>
                    <div class="app-modal-body">
                        <p>Are you sure you want to delete <strong>@_materialToDelete.Name</strong>?</p>
                        <p class="text-muted">This action cannot be undone.</p>
                    </div>
                    <div class="app-modal-footer">
                        <button class="btn" @onclick="CloseDeleteModal">Cancel</button>
                        <button class="btn btn-danger" @onclick="DeleteMaterial" disabled="@_isSaving">
                            @(_isSaving ? "Deleting..." : "Delete")
                        </button>
                    </div>
                </div>
            </div>
        }