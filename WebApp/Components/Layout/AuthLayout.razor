@inherits LayoutComponentBase

<div class="auth-layout">
    @Body
</div>

<style>
    .auth-layout {
        min-height: 100vh;
        background: #0d0d0d;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .auth-layout .auth-card {
        background: #1a1a1a;
        border: 1px solid #333;
        min-width: 380px;
        color: #e0e0e0;
    }

    .auth-layout .auth-card-header {
        background: #1a1a1a;
        border-bottom: 1px solid #333;
        padding: 1.25rem;
        text-align: center;
    }

    .auth-layout .auth-card-header h3 {
        margin: 0;
        color: #fff;
        font-weight: 600;
    }

    .auth-layout .auth-card-body {
        padding: 1.5rem;
    }

    .auth-layout .form-label {
        color: #aaa;
        font-size: 0.875rem;
        margin-bottom: 0.375rem;
    }

    .auth-layout .form-control {
        background: #0d0d0d;
        border: 1px solid #333;
        border-radius: 0;
        color: #e0e0e0;
        padding: 0.625rem 0.75rem;
    }

    .auth-layout .form-control:focus {
        background: #0d0d0d;
        border-color: #555;
        color: #e0e0e0;
        box-shadow: none;
        outline: none;
    }

    .auth-layout .form-control::placeholder {
        color: #666;
    }

    .auth-layout .btn-primary,
    .auth-layout .btn-submit {
        background: #333;
        border: 1px solid #444;
        border-radius: 0;
        color: #fff;
        padding: 0.625rem 1rem;
        width: 100%;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .auth-layout .btn-primary:hover,
    .auth-layout .btn-submit:hover {
        background: #444;
        border-color: #555;
    }

    .auth-layout .btn-primary:disabled {
        background: #222;
        border-color: #333;
        color: #666;
        cursor: not-allowed;
    }

    .auth-layout .alert-danger {
        background: transparent;
        border: 1px solid #ff4444;
        border-radius: 0;
        color: #ff6666;
        padding: 0.75rem;
        margin-bottom: 1rem;
    }

    .auth-layout .alert-success {
        background: transparent;
        border: 1px solid #44ff44;
        border-radius: 0;
        color: #66ff66;
        padding: 0.75rem;
        margin-bottom: 1rem;
    }

    .auth-layout hr {
        border: none;
        border-top: 1px solid #333;
        margin: 1.25rem 0;
    }

    .auth-layout a {
        color: #888;
        text-decoration: none;
    }

    .auth-layout a:hover {
        color: #fff;
        text-decoration: underline;
    }

    .auth-layout .text-center {
        text-align: center;
    }

    .auth-layout p {
        color: #888;
        margin: 0;
    }
</style>